# Environment
ENVIRONMENT=development
DEBUG=true
LOG_LEVEL=info

# Database
# For Docker Compose: use DATABASE_HOST=postgres
# For local Windows: use DATABASE_HOST=localhost
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_NAME=fraudwatch_db
DATABASE_USER=fraudwatch
DATABASE_PASSWORD=fraudwatch_password
DATABASE_ECHO=false

# Constructed URLs (do not edit directly - these are built from the settings above)
# DATABASE_URL=postgresql+asyncpg://fraudwatch:fraudwatch_password@localhost:5432/fraudwatch_db
# DATABASE_SYNC_URL=postgresql://fraudwatch:fraudwatch_password@localhost:5432/fraudwatch_db

# Redis
# For Docker Compose: use REDIS_HOST=redis
# For local Windows: use REDIS_HOST=localhost
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
# REDIS_URL=redis://localhost:6379/0

# Celery
CELERY_BROKER_DB=1
CELERY_RESULT_BACKEND_DB=2
# CELERY_BROKER_URL=redis://localhost:6379/1
# CELERY_RESULT_BACKEND=redis://localhost:6379/2

# JWT Authentication
JWT_SECRET_KEY=your-secret-key-change-in-production-use-openssl-rand-base64-32
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# Password Hashing
PASSWORD_SECRET_KEY=your-password-secret-key-change-in-production
PASSWORD_ALGORITHM=bcrypt
PASSWORD_ROUNDS=12

# API
API_V1_PREFIX=/api/v1
PROJECT_NAME=FraudWatch API
VERSION=1.0.0
DESCRIPTION=AI-Powered Financial Fraud Detection & Risk Intelligence Platform

# CORS
CORS_ORIGINS=["http://localhost:3000","http://localhost:3001"]
CORS_CREDENTIALS=true
CORS_METHODS=["*"]
CORS_HEADERS=["*"]

# Sentry (optional)
SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.1

# ML Model Paths
MODEL_PATH=./ml/artifacts
MODEL_VERSION=latest

# Rate Limiting
RATE_LIMIT_PER_MINUTE=60

# Pagination
DEFAULT_PAGE_SIZE=20
MAX_PAGE_SIZE=100
